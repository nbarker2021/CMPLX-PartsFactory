# CMPLX OpenCode Session Container
# =================================
# Synthesized from:
#   - opencode-docker-agent/Dockerfile (node base, docker cli, gh cli, entrypoint)
#   - opencode_agent_ecosystem_mvp/controller/Dockerfile (python slim pattern)
#   - CMPLX-Monorepo runtime containers (multi-language support)
#
# This Dockerfile builds the primary agent runtime for CMPLX-PartsFactory.
# It combines Node.js (for opencode), Python (for CMPLX tooling),
# Docker CLI (for in-container compose), and system utilities.

ARG NODE_VERSION=22
FROM node:${NODE_VERSION}-bookworm-slim

ARG OPENCODE_NPM_PACKAGE=opencode-ai@latest
ENV DEBIAN_FRONTEND=noninteractive \
    HOME=/home/opencode \
    SHELL=/bin/bash

# ── System dependencies ────────────────────────────────────────────
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
      bash ca-certificates curl wget git openssh-client gnupg lsb-release \
      jq ripgrep fd-find less nano vim-tiny tmux procps sudo unzip zip tar gzip xz-utils zstd \
      make gcc g++ python3 python3-pip python3-venv pipx \
      iproute2 iputils-ping dnsutils netcat-openbsd tini gosu \
      sqlite3 postgresql-client redis-tools \
    && rm -rf /var/lib/apt/lists/*

# ── Docker CLI + Compose v2 + Buildx ──────────────────────────────
# This image uses the host Docker socket by default.
RUN install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg \
    && chmod a+r /etc/apt/keyrings/docker.gpg \
    && . /etc/os-release \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/debian ${VERSION_CODENAME} stable" > /etc/apt/sources.list.d/docker.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends docker-ce-cli docker-compose-plugin docker-buildx-plugin \
    && rm -rf /var/lib/apt/lists/*

# ── GitHub CLI ────────────────────────────────────────────────────
RUN install -m 0755 -d /etc/apt/keyrings \
    && curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg | dd of=/etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && chmod go+r /etc/apt/keyrings/githubcli-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" > /etc/apt/sources.list.d/github-cli.list \
    && apt-get update \
    && apt-get install -y --no-install-recommends gh \
    && rm -rf /var/lib/apt/lists/*

# ── Python environment ─────────────────────────────────────────────
ENV PYTHONPATH=/workspace/PartsFactory/CMPLX-PartsFactory/src
ENV PYTHONUNBUFFERED=1
ENV PIP_NO_CACHE_DIR=1

RUN pip3 install --break-system-packages \
    numpy>=1.24.0 \
    fastapi>=0.100.0 \
    uvicorn>=0.23.0 \
    httpx>=0.28.0 \
    mcp>=1.2.0 \
    requests>=2.31.0 \
    pytest>=7.4.0 \
    pytest-asyncio>=0.21.0 \
    discord.py>=2.3.0 \
    aiohttp>=3.8.0 \
    psycopg2-binary>=2.9.0 \
    redis>=5.0.0 \
    duckdb>=0.10.0 \
    pypdf>=4.0.0 \
    python-docx>=1.1.0 \
    markdown>=3.5.0 \
    flask>=3.0.0 \
    pydantic>=2.0.0 \
    uvicorn[standard]

# ── Node.js / OpenCode ─────────────────────────────────────────────
RUN npm install -g --force opencode-ai@latest

# ── Entrypoint scripts ─────────────────────────────────────────────
COPY scripts/opencode-entrypoint.sh /usr/local/bin/opencode-entrypoint
COPY scripts/self-compose /usr/local/bin/self-compose
RUN chmod +x /usr/local/bin/opencode-entrypoint /usr/local/bin/self-compose \
    && git config --system --add safe.directory '*'

# ── Working directories ────────────────────────────────────────────
WORKDIR /workspace

RUN mkdir -p \
    /workspace/PartsFactory \
    /workspace/MannyUnification2 \
    /workspace/OCbuild \
    /workspace/logs \
    /workspace/.opencode \
    /workspace/.cache \
    /tmp/cmplx

# ── Health check ───────────────────────────────────────────────────
EXPOSE 8080 4096

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD curl -fsS http://127.0.0.1:8080/health || exit 1

# ── Entrypoint ─────────────────────────────────────────────────────
ENTRYPOINT ["/usr/local/bin/opencode-entrypoint"]
CMD ["sleep", "infinity"]
