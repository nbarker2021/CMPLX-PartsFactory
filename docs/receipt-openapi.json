  "components": {
    "schemas": {
      "DagEdgeRequest": {
        "properties": {
          "source_id": {
            "type": "string",
            "title": "Source Id"
          },
          "target_id": {
            "type": "string",
            "title": "Target Id"
          },
          "edge_type": {
            "type": "string",
            "title": "Edge Type",
            "default": "depends"
          },
          "weight": {
            "type": "number",
            "title": "Weight",
            "default": 1.0
          },
          "snap_overlap": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Snap Overlap",
            "default": []
          }
        },
        "type": "object",
        "required": [
          "source_id",
          "target_id"
        ],
        "title": "DagEdgeRequest"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "ReceiptRequest": {
        "properties": {
          "receipt_type": {
            "type": "string",
            "title": "Receipt Type",
            "default": "PROCESS"
          },
          "agent_id": {
            "type": "string",
            "title": "Agent Id",
            "default": ""
          },
          "atom_id": {
            "type": "string",
            "title": "Atom Id",
            "default": ""
          },
          "operation": {
            "type": "string",
            "title": "Operation",
            "default": ""
          },
          "operator": {
            "type": "string",
            "title": "Operator",
            "default": ""
          },
          "payload": {
            "additionalProperties": true,
            "type": "object",
            "title": "Payload",
            "default": {}
          },
          "delta_phi": {
            "type": "number",
            "title": "Delta Phi",
            "default": 0.0
          },
          "snap_labels": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Snap Labels",
            "default": []
          },
          "epoch": {
            "type": "integer",
            "title": "Epoch",
            "default": 0
          },
          "parent_hash": {
            "type": "string",
            "title": "Parent Hash",
            "default": ""
          }
        },
        "type": "object",
        "title": "ReceiptRequest"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      },
      "VerifyRequest": {
        "properties": {
          "receipt_hash": {
            "type": "string",
            "title": "Receipt Hash",
            "default": ""
          },
          "max_depth": {
            "type": "integer",
            "title": "Max Depth",
            "default": 100
          }
        },
        "type": "object",
        "title": "VerifyRequest"
      }
