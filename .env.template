# CMPLX-PartsFactory Environment Template
# =========================================
# Copy to .env and fill in required values.
# NEVER commit .env to git.

# ── REQUIRED: Remote Access Auth ──
# Get ngrok token at https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_token_here
# Set a strong password for remote opencode API access
OPENCODE_SERVER_PASSWORD=change-me-to-a-strong-password

# ── Critical Paths ──
HOST_PROJECT_DIR=/mnt/d/PartsFactory/CMPLX-PartsFactory
HOST_PARTS_FACTORY=/mnt/d/PartsFactory
HOST_MANNY_UNIFICATION=/mnt/d/Manny Unification 2
HOST_OC_BUILD=/mnt/d/OC build

# ── Discord ──
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNELS=

# ── API Routing ──
DEFAULT_API=research
REPO_KERNEL_PORT=8786
REPO_KERNEL_ALLOW_MUTATION=0
RESEARCH_API_URL=http://cmplx-unified-api:8851
MANNY_RUNTIME_URL=http://manny-runtime:8870

# ── Database ──
POSTGRES_USER=manny
POSTGRES_PASSWORD=CHANGE_ME
CACHE_POSTGRES_USER=manny
CACHE_POSTGRES_PASSWORD=CHANGE_ME

# ── RabbitMQ ──
RABBITMQ_USER=manny
RABBITMQ_PASS=CHANGE_ME

# ── MinIO ──
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME

# ── Model Routing ──
DEFAULT_MODEL=deepseek-v4-flash-free
SMALL_MODEL=deepseek-v4-flash-free
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL_GEMMA=gemma3:4b

# ── Ports ──
OPENCODE_PORT=8080
OLLAMA_PORT=11434
PROMETHEUS_PORT=59090
GRAFANA_PORT=59030

# ── Controller Policy ──
GLOBAL_DAILY_MESSAGE_LIMIT=250
PER_WORKER_DAILY_MESSAGE_LIMIT=75
MAX_MESSAGE_CHARS=24000
MAX_PARALLEL_TASKS=3
